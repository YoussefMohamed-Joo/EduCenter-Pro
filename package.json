{
  "name": "educenter-pro",
  "version": "1.0.1",
  "description": "EduCenter Pro - Professional Student Management System",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "publish": "vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/electron": "^7.13.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "framer-motion": "^11.2.10",
    "jsbarcode": "^3.11.6",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.24.1",
    "react-window": "^1.8.10",
    "recharts": "^3.8.1",
    "sql.js": "^1.14.1",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^42.4.1",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.educenter.pro",
    "productName": "EduCenter Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/sql.js/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "win": {
      "target": "nsis",
      "publish": [
        "github"
      ],
      "icon": null
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "publish": [
        "github"
      ],
      "category": "public.app-category.education",
      "icon": null
    },
    "dmg": {
      "title": "EduCenter Pro ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "differentialPackage": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "YoussefMohamed-Joo",
      "repo": "EduCenter-Pro",
      "releaseType": "release"
    }
  }
}
